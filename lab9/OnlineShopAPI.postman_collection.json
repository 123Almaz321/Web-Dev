{
  "info": {
    "name": "Online Shop API",
    "_postman_id": "online-shop-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/categories/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", ""] } }
        },
        {
          "name": "Get Category by ID",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/categories/1/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", "1", ""] } }
        },
        {
          "name": "Get Products by Category",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/categories/1/products/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", "1", "products", ""] } }
        },
        {
          "name": "Create Category",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\": \"New Category\"}" }, "url": { "raw": "http://localhost:8000/api/categories/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", ""] } }
        },
        {
          "name": "Update Category",
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\": \"Updated Category\"}" }, "url": { "raw": "http://localhost:8000/api/categories/1/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", "1", ""] } }
        },
        {
          "name": "Delete Category",
          "request": { "method": "DELETE", "url": { "raw": "http://localhost:8000/api/categories/1/", "host": ["localhost"], "port": "8000", "path": ["api", "categories", "1", ""] } }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/products/", "host": ["localhost"], "port": "8000", "path": ["api", "products", ""] } }
        },
        {
          "name": "Get Product by ID",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/products/1/", "host": ["localhost"], "port": "8000", "path": ["api", "products", "1", ""] } }
        },
        {
          "name": "Create Product",
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\": \"New Product\", \"price\": 99.99, \"description\": \"Product description\", \"count\": 10, \"is_active\": true, \"category\": 1}" }, "url": { "raw": "http://localhost:8000/api/products/", "host": ["localhost"], "port": "8000", "path": ["api", "products", ""] } }
        },
        {
          "name": "Update Product",
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\": \"Updated Product\", \"price\": 199.99, \"description\": \"Updated description\", \"count\": 5, \"is_active\": true, \"category\": 1}" }, "url": { "raw": "http://localhost:8000/api/products/1/", "host": ["localhost"], "port": "8000", "path": ["api", "products", "1", ""] } }
        },
        {
          "name": "Delete Product",
          "request": { "method": "DELETE", "url": { "raw": "http://localhost:8000/api/products/1/", "host": ["localhost"], "port": "8000", "path": ["api", "products", "1", ""] } }
        }
      ]
    },
    {
      "name": "Search & Filters",
      "item": [
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/products/?search=phone", "host": ["localhost"], "port": "8000", "path": ["api", "products", ""], "query": [{ "key": "search", "value": "phone" }] } }
        },
        {
          "name": "Sort Products by Price",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8000/api/products/?ordering=-price", "host": ["localhost"], "port": "8000", "path": ["api", "products", ""], "query": [{ "key": "ordering", "value": "-price" }] } }
        }
      ]
    }
  ]
}